{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "strict": true,
        "outDir": "dist",
        "rootDir": "lib",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true
    },
    "include": [
        "lib"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
