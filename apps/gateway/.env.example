# Internal Cloud Run service hostnames (VPC-internal)
STOREFRONT_HOST=storefront.internal
STOREFRONT_PORT=3000

ORDER_SERVICE_HOST=order-service.internal
ORDER_SERVICE_PORT=8082

CATALOG_SERVICE_HOST=catalog-service.internal
CATALOG_SERVICE_PORT=8083

AGENT_SERVICE_HOST=agent-service.internal
AGENT_SERVICE_PORT=8088

# JWT auth sidecar — required for gateway-level authentication
# Get this from Supabase dashboard: Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
