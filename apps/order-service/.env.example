GOOGLE_CLOUD_PROJECT=trovestak
NODE_ENV=development
PORT=8082

NEXT_PUBLIC_SUPABASE_URL=https://lgxqlgyciazmlllowhel.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Pub/Sub subscriptions this service consumes
PUBSUB_SUBSCRIPTION_PAYMENT_CONFIRMED=order-payment-confirmed
PUBSUB_SUBSCRIPTION_PAYMENT_FAILED=order-payment-failed

# Pub/Sub topics this service publishes to
PUBSUB_TOPIC_ORDER_CREATED=order.created
PUBSUB_TOPIC_PAYMENT_INITIATE=payment.initiate
PUBSUB_TOPIC_ORDER_DISPATCHED=order.dispatched
PUBSUB_TOPIC_ORDER_UPDATED=order.updated

# Dev: direct fallback to mpesa-service when PubSub unavailable
MPESA_SERVICE_URL=http://localhost:8081

# Shared secret for storefront → order-service admin calls
SERVICE_SECRET=change-me-in-production
