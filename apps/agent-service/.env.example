# agent-service environment variables
# Copy to .env and fill in values

# Google Cloud
GOOGLE_CLOUD_PROJECT=trovestak-prod
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Gemini
GEMINI_API_KEY=your-gemini-2-flash-api-key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pub/Sub
PUBSUB_TOPIC_PAYMENT_INITIATE=payment.initiate
PUBSUB_TOPIC_AGENT_INTENT=agent.intent
PUBSUB_SUBSCRIPTION_PAYMENT_CONFIRMED=payment-confirmed-agent-sub

# Server
PORT=8080
NODE_ENV=development
