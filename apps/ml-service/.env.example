# ml-service environment variables
GOOGLE_CLOUD_PROJECT=trovestak-prod
PUBSUB_SUBSCRIPTION_ORDER_CREATED_ML=order-created-ml-sub
PUBSUB_SUBSCRIPTION_USER_EVENTS_ML=user-events-ml-sub
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vertex AI
VERTEX_AI_REGION=us-central1
VERTEX_AI_ENDPOINT_RECOMMENDATIONS=projects/YOUR_PROJECT/locations/us-central1/endpoints/YOUR_ENDPOINT_ID

# BigQuery
BIGQUERY_DATASET=trovestak_features
BIGQUERY_TABLE_ORDERS=order_features
BIGQUERY_TABLE_PRODUCTS=product_features

# Pub/Sub
PUBSUB_SUBSCRIPTION_ORDER_CREATED=order-created-ml-sub
PUBSUB_TOPIC_RECOMMENDATION_READY=recommendation.ready

PORT=8001
